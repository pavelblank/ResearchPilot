# ResearchPilot — AI Configuration
# Edit this file to set your AI keys, then restart the server.
#
# The system auto-picks: Ollama (local) → Gemini → none
# ─────────────────────────────────────────────────────────

# ── Gemini API Key (Google AI Studio) ──────────────────────
# Get free key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=paste_your_key_here

# ── Ollama model (if you have Ollama installed locally) ─────
# Default is llama3. Change to any model you have pulled.
# OLLAMA_MODEL=llama3
# OLLAMA_MODEL=mistral
# OLLAMA_MODEL=phi3

# ── Server binding ──────────────────────────────────────────
# HOST=127.0.0.1   # Uncomment to change; 127.0.0.1 = local only (recommended)
PORT=8000
