dist/
build/

# OS
Thumbs.db
.DS_Store
Desktop.ini
*.bak
*.tmp
*.swp

# Research content (papers, extractions, projects)
# Allow the project template (blueprint) but ignore all real project data
01-PROJECTS/*
!01-PROJECTS/00-TEMPLATE/
!01-PROJECTS/00-TEMPLATE/**

# Web-research per-project configs (P1, P2, …). Keep the template DEFAULT.json.
00-SYSTEM-CORE/SEARCH-SYSTEM/projects/P[0-9]-*.json
# Allow INCOMING/ and UNREAD-WEB/ folders to exist on clone (.gitkeep only);
# user papers placed there remain ignored.
INCOMING/*
!INCOMING/.gitkeep
!INCOMING/UNREAD-WEB/
!INCOMING/UNREAD-WEB/.gitkeep
!INCOMING/UNREAD-WEB/**
*.pdf
*.epub
*.caj
*.ps
99-SYSTEM-BACKEND/MASTER_LIBRARY_BACKUP.csv
99-SYSTEM-BACKEND/chats/*.md

# Obsidian
.obsidian/
.claude/
.tmp.driveupload/
.tmp.drivedownload/

# Local backups (keep locally, not on GitHub)
Version 5.1/
graphify-out/

# Filename migration artifacts (transient; one-shot, opt-in, user-controlled)
99-SYSTEM-BACKEND/filename_migration_backup/
99-SYSTEM-BACKEND/migration_plan_*.json
!99-SYSTEM-BACKEND/filename_migration_backup/.gitkeep

# Web-research test outputs (auto-generated by EVALUATE-RESULT / FILTER-PAPERS runs)
00-SYSTEM-CORE/SEARCH-SYSTEM/test-cases/*.csv
00-SYSTEM-CORE/SEARCH-SYSTEM/test-cases/*.evaluated.csv

# Temp / logs
*.log
*.tmp
stderr.txt
stdout.txt
web-app/stdout.txt
web-app/stderr.txt

# IDE / debug
.vscode/
*.canvas
web-app/_debug_*.py
web-app/test_*.py
!web-app/test_smoke.py
